        <!-- ==================== CRONJOBS SECTION ==================== -->
        <mxCell id="cron_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;strokeWidth=2;dashed=0;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1160" y="150" width="270" height="490" as="geometry" />
        </mxCell>
        <mxCell id="cron_title" value="&lt;font style=&quot;font-size:13px;font-weight:bold;color:#C62828;&quot;&gt;⏰ CronJobs — Certificate Lifecycle&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1175" y="158" width="248" height="25" as="geometry" />
        </mxCell>

        <!-- ============ CRONJOB 1: Pod Cert Renewal ============ -->
        <mxCell id="cron1" value="&lt;b&gt;CronJob 1: pod-cert-renewal&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#555;&quot;&gt;schedule: &quot;0 2 * * *&quot; (daily 2AM)&lt;br&gt;&lt;br&gt;1. openssl s_client -connect&lt;br&gt;   my-svc.my-ns:8443&lt;br&gt;2. openssl x509 -checkend 604800&lt;br&gt;   (7 days before expiry)&lt;br&gt;3. IF expiring:&lt;br&gt;   → vault write pki_int/issue/pod-role&lt;br&gt;   → oc rollout restart deploy/my-ms&lt;br&gt;4. ELSE: exit 0 (cert still valid)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=1.5;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1175" y="195" width="240" height="175" as="geometry" />
        </mxCell>

        <!-- ============ CRONJOB 2: Route Cert Renewal ============ -->
        <mxCell id="cron2" value="&lt;b&gt;CronJob 2: route-cert-renewal&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#555;&quot;&gt;schedule: &quot;0 3 * * *&quot; (daily 3AM)&lt;br&gt;&lt;br&gt;1. openssl s_client -connect&lt;br&gt;   my-svc.my-ns.svc:8443&lt;br&gt;   -servername app.example.com&lt;br&gt;2. openssl x509 -checkend 604800&lt;br&gt;   (7 days before expiry)&lt;br&gt;3. IF expiring:&lt;br&gt;   → vault write pki_int/issue/route-role&lt;br&gt;   → oc patch route my-route&lt;br&gt;     --type=merge -p '{...tls certs...}'&lt;br&gt;4. ELSE: exit 0 (cert still valid)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=1.5;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1175" y="395" width="240" height="200" as="geometry" />
        </mxCell>

        <!-- ============ CRONJOB ARROWS ============ -->
        <mxCell id="arrow_cron1_svc" value="&lt;font style=&quot;font-size:9px;color:#C62828;&quot;&gt;openssl s_client&lt;br&gt;:8443&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;exitX=0;exitY=0.4;entryX=1;entryY=0.5;strokeColor=#C62828;strokeWidth=1.5;dashed=1;" edge="1" source="cron1" target="nginx" parent="1">
