              <mxPoint x="1000" y="762" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="arrow_cron2_vault" value="&lt;font style=&quot;font-size:9px;color:#FFB300;&quot;&gt;Renew&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;exitX=0.5;exitY=1;entryX=1;entryY=0.7;strokeColor=#FFB300;strokeWidth=1.5;dashed=1;dashPattern=6 3;" edge="1" source="cron2" target="vault_box" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1295" y="870" />
              <mxPoint x="990" y="870" />
              <mxPoint x="990" y="818" />
            </Array>
