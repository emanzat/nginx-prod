        <mxCell id="init2_badge" value="&lt;font style=&quot;font-size:8px;color:#FFF;&quot;&gt;②&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1565C0;strokeColor=none;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="745" y="190" width="20" height="20" as="geometry" />
        </mxCell>

        <!-- ============ INIT CONTAINER 3: Create Route ============ -->
        <mxCell id="init3" value="&lt;b&gt;Init Container 3&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#555;&quot;&gt;create-reencrypt-route&lt;br&gt;&lt;br&gt;oc get route || oc create route&lt;br&gt;reencrypt my-route&lt;br&gt;  --cert=/tls/route/route.crt&lt;br&gt;  --key=/tls/route/route.key&lt;br&gt;  --ca-cert=/tls/route/ca.crt&lt;br&gt;  --dest-ca-cert=/tls/pod/ca.crt&lt;br&gt;  --service=my-svc&lt;br&gt;  --port=8443&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=1.5;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
