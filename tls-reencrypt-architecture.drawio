          <mxGeometry x="830" y="420" width="130" height="70" as="geometry" />
        </mxCell>
        <mxCell id="vol_route" value="&lt;font style=&quot;font-size:9px;&quot;&gt;📁 &lt;b&gt;emptyDir&lt;/b&gt;&lt;br&gt;medium: Memory&lt;br&gt;/tls/route&lt;br&gt;&lt;i&gt;route.crt, route.key, ca.crt&lt;/i&gt;&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=8;fillColor=#E8EAF6;strokeColor=#3949AB;fontSize=9;align=center;" vertex="1" parent="1">
