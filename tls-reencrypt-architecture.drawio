        <!-- ============ INIT CONTAINER 2: Get Route Cert ============ -->
        <mxCell id="init2" value="&lt;b&gt;Init Container 2&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#555;&quot;&gt;vault-get-route-cert&lt;br&gt;&lt;br&gt;vault write pki_int/issue/route-role&lt;br&gt;→ route.crt + route.key + ca.crt&lt;br&gt;→ mount: /tls/route&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=1.5;fontSize=10;align=center;" vertex="1" parent="1">
