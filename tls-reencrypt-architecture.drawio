        <!-- ==================== VAULT PKI (EXTERNAL) ==================== -->
        <mxCell id="vault_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF;strokeColor=#FFB300;strokeWidth=2;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="720" width="260" height="140" as="geometry" />
