        <!-- ==================== SERVICE ==================== -->
        <mxCell id="svc" value="&lt;b&gt;Service: my-svc&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#555;&quot;&gt;port: 8443 → targetPort: 8443&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00695C;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
