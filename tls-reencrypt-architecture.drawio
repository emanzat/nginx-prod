        <mxCell id="vault_pki2" value="&lt;font style=&quot;font-size:10px;&quot;&gt;&lt;b&gt;PKI Engine: route-role&lt;/b&gt;&lt;br&gt;CN=app.example.com&lt;br&gt;TTL=90d&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FFB300;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="855" y="760" width="115" height="55" as="geometry" />
