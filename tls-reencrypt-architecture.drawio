          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1130" y="535" />
              <mxPoint x="500" y="535" />
              <mxPoint x="500" y="286" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="arrow_cron1_vault" value="&lt;font style=&quot;font-size:9px;color:#FFB300;&quot;&gt;Renew&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;exitX=0.5;exitY=1;entryX=1;entryY=0.3;strokeColor=#FFB300;strokeWidth=1.5;dashed=1;dashPattern=6 3;" edge="1" source="cron1" target="vault_box" parent="1">
          <mxGeometry relative="1" as="geometry">
