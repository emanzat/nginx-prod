#!/bin/bash

MIN_HOURS=2
THRESHOLD=$((MIN_HOURS * 3600))
SVC_HOST="ap08680-deploy-int-c02-optima-service.ns002i012859.svc.cluster.local"
SVC_PORT=10443
NAMESPACE="ns002i012859"
DEPLOYMENT="ap08680-deploy-int-c02-optima"

# Récupère le cert et vérifie s'il expire dans moins de THRESHOLD secondes
if echo | openssl s_client -connect "${SVC_HOST}:${SVC_PORT}" 2>/dev/null \
   | openssl x509 -checkend "${THRESHOLD}" -noout 2>/dev/null; then
  # checkend retourne 0 => le cert est encore valide APRÈS le seuil
  # Donc il reste > 2h => on peut rollout restart sereinement
  echo "Cert valide > ${MIN_HOURS}h - rollout restart pour renouvellement"
  kubectl rollout restart "deployment/${DEPLOYMENT}" -n "${NAMESPACE}"
  kubectl rollout status "deployment/${DEPLOYMENT}" -n "${NAMESPACE}" --timeout=300s
else
  # checkend retourne 1 => le cert expire AVANT le seuil (< 2h) ou connexion impossible
  echo "Cert expire dans < ${MIN_HOURS}h ou connexion impossible - on ne fait rien"
fi
