<script>
var state = { C: null, I: null, D: null, T: null };
var activeICP = null;
var ICP_LIST = ['low','mod','ser','ext'];

function toggleOpt(btn) {
  var crit = btn.getAttribute('data-crit');
  var icp  = btn.getAttribute('data-icp');
  var allOpts = document.querySelectorAll('.opt[data-crit="' + crit + '"]');
  for (var i = 0; i < allOpts.length; i++) { allOpts[i].className = 'opt'; }
  if (state[crit] === icp) {
    state[crit] = null;
  } else {
    state[crit] = icp;
    btn.className = 'opt on-' + icp;
    setICP(icp);
  }
  applyHighlights();
}

function toggleICP(btn) {
  var icp = btn.getAttribute('data-icp');
  setICP(activeICP === icp ? null : icp);
  applyHighlights();
}

function setICP(icp) {
  activeICP = icp;
  var pills = document.querySelectorAll('.icp-pill');
  for (var i = 0; i < pills.length; i++) {
    pills[i].className = 'icp-pill';
    if (pills[i].getAttribute('data-icp') === icp) {
      pills[i].className = 'icp-pill icp-' + icp;
    }
  }
  for (var j = 0; j < ICP_LIST.length; j++) {
    var c = ICP_LIST[j];
    var hidden = (icp !== null && c !== icp);
    var th = document.getElementById('th-' + c);
    if (th) {
      th.className = 'th-icp icp-' + c + (hidden ? ' col-dim' : '');
    }
    var tds = document.querySelectorAll('td.td-c[data-icp="' + c + '"]');
    for (var k = 0; k < tds.length; k++) {
      var cur = tds[k].className.replace(' col-dim','');
      tds[k].className = cur + (hidden ? ' col-dim' : '');
    }
  }
}

function applyHighlights() {
  // Clear table active cells
  var allTd = document.querySelectorAll('td.td-c');
  for (var i = 0; i < allTd.length; i++) {
    allTd[i].className = allTd[i].className.replace(' active-cell','');
  }
  // Clear mobile card active blocks
  var allLb = document.querySelectorAll('.lb');
  for (var i = 0; i < allLb.length; i++) {
    allLb[i].className = allLb[i].className.replace(' active-card','');
  }
  var crits = ['C','I','D','T'];
  for (var j = 0; j < crits.length; j++) {
    var crit = crits[j];
    var v = state[crit];
    if (!v) continue;
    // Desktop table cell
    var td = document.querySelector('td.td-c[data-crit="' + crit + '"][data-icp="' + v + '"]');
    if (td) { td.className = td.className.replace(' active-cell','') + ' active-cell'; }
    // Mobile card block
    var lb = document.querySelector('.lb[data-crit="' + crit + '"][data-icp="' + v + '"]');
    if (lb) { lb.className = lb.className.replace(' active-card','') + ' active-card'; }
    // Mobile card header color
    var mhead = document.getElementById('mhead-' + crit);
    if (mhead) { mhead.className = 'ccard-head hl-' + v; }
  }
}

function resetAll() {
  state = { C: null, I: null, D: null, T: null };
  var opts = document.querySelectorAll('.opt');
  for (var i = 0; i < opts.length; i++) { opts[i].className = 'opt'; }
  setICP(null);
  applyHighlights();
  var heads = ['mhead-C','mhead-I','mhead-D','mhead-T'];
  for (var j = 0; j < heads.length; j++) {
    var h = document.getElementById(heads[j]);
    if (h) { h.className = 'ccard-head'; }
  }
}
</script>

