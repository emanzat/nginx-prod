        <mxCell id="e06" value="Oui" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;fontColor=#82b366;fontSize=11;fontStyle=1;html=0;" parent="1" source="s1_check_active" target="s1_extract" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e07" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#6c8ebf;" parent="1" source="s1_extract" target="s1_decision" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e08" value="Non (token valide)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;fontColor=#82b366;fontSize=10;fontStyle=1;html=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="s1_decision" target="s1_ok" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="335" y="620" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e09" value="Oui (expire dans 20j ou moins)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#b85450;fontColor=#b85450;fontSize=10;fontStyle=1;html=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" parent="1" source="s1_decision" target="s1_renew_flag" edge="1">
          <mxGeometry x="0.5" relative="1" as="geometry">
