        </mxCell>
        <mxCell id="legend_title" value="Legende" style="text;html=0;align=center;fontSize=13;fontStyle=1;fontColor=#333333;" parent="1" vertex="1">
          <mxGeometry x="1140" y="90" width="80" height="20" as="geometry" />
