        <mxCell id="leg1" value="" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="1085" y="115" width="16" height="14" as="geometry" />
        </mxCell>
        <mxCell id="leg1t" value="Etape CI/CD" style="text;html=0;align=left;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="1108" y="113" width="90" height="18" as="geometry" />
        </mxCell>
        <mxCell id="leg2" value="" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="1083" y="136" width="16" height="14" as="geometry" />
        </mxCell>
        <mxCell id="leg2t" value="Decision" style="text;html=0;align=left;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="1108" y="134" width="90" height="18" as="geometry" />
        </mxCell>
        <mxCell id="leg3" value="" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="1085" y="157" width="16" height="14" as="geometry" />
        </mxCell>
        <mxCell id="leg3t" value="Appel API (self)" style="text;html=0;align=left;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="1108" y="155" width="110" height="18" as="geometry" />
        </mxCell>
        <mxCell id="leg4" value="" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="1085" y="178" width="16" height="14" as="geometry" />
        </mxCell>
        <mxCell id="leg4t" value="Erreur" style="text;html=0;align=left;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="1108" y="176" width="60" height="18" as="geometry" />
        </mxCell>
        <mxCell id="start" value="" style="ellipse;fillColor=#9673a6;strokeColor=#9673a6;strokeWidth=3;" parent="1" vertex="1">
          <mxGeometry x="105" y="135" width="40" height="40" as="geometry" />
        </mxCell>
        <mxCell id="schedule" value="Schedule CI/CD&#xa;Cron hebdomadaire&#xa;(ex: lundi 8h)" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#e1d5e7;strokeColor=#9673a6;shadow=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="50" y="210" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s1_init" value="Image: alpine:3.19&#xa;apk add curl jq coreutils" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#dae8fc;strokeColor=#6c8ebf;shadow=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="320" y="135" width="210" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s1_api_self" value="GET /personal_access_tokens/self&#xa;Header: PRIVATE-TOKEN: $TOKEN_GITLAB&#xa;(le token s&#39;inspecte lui-meme)" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="300" y="230" width="250" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s1_check_active" value="Token&#xa;actif ?" style="rhombus;whiteSpace=wrap;html=0;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="375" y="340" width="100" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s1_extract" value="Extraire expires_at&#xa;Calculer DAYS_LEFT&#xa;= (expires_at - now) / 86400" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#dae8fc;strokeColor=#6c8ebf;shadow=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="310" y="465" width="230" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s1_decision" value="DAYS_LEFT&#xa;&lt;= 20 ?" style="rhombus;whiteSpace=wrap;html=0;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="365" y="575" width="120" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s1_renew_flag" value="NEEDS_RENEWAL=true&#xa;OLD_TOKEN_ID=$id&#xa;dotenv artifact" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#f8cecc;strokeColor=#b85450;shadow=1;fontSize=11;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="350" y="880" width="200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s2_gate" value="rules:&#xa;NEEDS_RENEWAL&#xa;== true ?" style="rhombus;whiteSpace=wrap;html=0;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;fontSize=11;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="780" y="130" width="130" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s2_create" value="POST /users/:id/personal_access_tokens&#xa;Header: PRIVATE-TOKEN: $TOKEN_GITLAB&#xa;name, scopes, expires_at: +365j&#xa;(le token cree son successeur)" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="720" y="280" width="290" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s2_check_new" value="Nouveau&#xa;token recu ?" style="rhombus;whiteSpace=wrap;html=0;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="790" y="410" width="130" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s2_error" value="ERREUR&#xa;Echec creation&#xa;exit 1" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#f8cecc;strokeColor=#b85450;shadow=1;fontSize=11;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="950" y="415" width="120" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s2_update" value="PUT /projects/:id/variables/TOKEN_GITLAB&#xa;Header: PRIVATE-TOKEN: $TOKEN_GITLAB&#xa;value=$NEW_TOKEN&#xa;masked=true, protected=true" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="720" y="540" width="290" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s2_fallback" value="HTTP&#xa;200 ?" style="rhombus;whiteSpace=wrap;html=0;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="800" y="670" width="100" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s2_create_var" value="POST /projects/:id/variables&#xa;key=TOKEN_GITLAB&#xa;(fallback si 404)" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="940" y="675" width="190" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s2_revoke" value="DELETE /personal_access_tokens/:id&#xa;Header: PRIVATE-TOKEN: $NEW_TOKEN&#xa;Revocation ancien token" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#dae8fc;strokeColor=#6c8ebf;shadow=1;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="730" y="800" width="270" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s2_done" value="SUCCES - Self-Renewal termine&#xa;TOKEN_GITLAB = nouveau token&#xa;Prochaine expiration : +365j" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;strokeWidth=3;fontSize=11;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="740" y="920" width="250" height="55" as="geometry" />
        </mxCell>
        <mxCell id="end" value="" style="ellipse;fillColor=#1a1a2e;strokeColor=#1a1a2e;strokeWidth=3;" parent="1" vertex="1">
          <mxGeometry x="850" y="1010" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="vars_box" value="Variables CI/CD requises&#xa;------&#xa;TOKEN_GITLAB : PAT (scope: api) [masked]&#xa;GITLAB_USER_ID : ID du user&#xa;TOKEN_NAME : Nom du token&#xa;TOKEN_SCOPES : Scopes (api read_repository)&#xa;RENEW_THRESHOLD_DAYS : Seuil (20)&#xa;TOKEN_VALIDITY_DAYS : Duree (365)" style="shape=note;size=15;whiteSpace=wrap;html=0;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=10;shadow=1;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="1070" y="230" width="250" height="150" as="geometry" />
        </mxCell>
        <mxCell id="principle_box" value="Principe du Self-Renewal&#xa;------&#xa;1. Le token (scope: api) peut&#xa;   creer d&#39;autres tokens&#xa;2. Tant qu&#39;il est valide, il&#xa;   genere son successeur&#xa;3. Il ecrase sa propre variable&#xa;   CI/CD avec la nouvelle valeur&#xa;4. Il se fait revoquer par&#xa;   le nouveau token" style="shape=note;size=15;whiteSpace=wrap;html=0;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=10;shadow=1;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="1070" y="410" width="240" height="180" as="geometry" />
        </mxCell>
        <mxCell id="warning_box" value="ATTENTION&#xa;------&#xa;Si le token expire avant&#xa;le renouvellement, une&#xa;intervention manuelle sera&#xa;necessaire pour recreer&#xa;un token initial." style="shape=note;size=15;whiteSpace=wrap;html=0;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=10;shadow=1;fontSize=10;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="1070" y="620" width="220" height="130" as="geometry" />
        </mxCell>
        <mxCell id="e01" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#9673a6;" parent="1" source="start" target="schedule" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e02" value="Declenche" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#6c8ebf;fontSize=10;html=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.386;entryY=0.956;entryDx=0;entryDy=0;entryPerimeter=0;" parent="1" source="schedule" target="s1_init" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="210" y="240" />
              <mxPoint x="210" y="200" />
              <mxPoint x="401" y="200" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e03" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#6c8ebf;" parent="1" source="s1_init" target="s1_api_self" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e04" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;" parent="1" source="s1_api_self" target="s1_check_active" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e05" value="Non" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#b85450;fontColor=#b85450;fontSize=11;fontStyle=1;html=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" parent="1" source="s1_check_active" target="s1_error_expired" edge="1">
          <mxGeometry relative="1" as="geometry" />
