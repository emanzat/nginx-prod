        <mxCell id="e13" value="Non" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#b85450;fontColor=#b85450;fontSize=11;fontStyle=1;html=0;" parent="1" source="s2_check_new" target="s2_error" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e14" value="Oui" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;fontColor=#82b366;fontSize=11;fontStyle=1;html=0;" parent="1" source="s2_check_new" target="s2_update" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e15" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;" parent="1" source="s2_update" target="s2_fallback" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e16" value="404" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#d6b656;fontColor=#d6b656;fontSize=11;fontStyle=1;html=0;" parent="1" source="s2_fallback" target="s2_create_var" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e17" value="200" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;fontColor=#82b366;fontSize=11;fontStyle=1;html=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" parent="1" source="s2_fallback" target="s2_revoke" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e18" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;" parent="1" source="s2_create_var" target="s2_revoke" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e19" value="Ancien token revoque" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;fontColor=#82b366;fontSize=10;html=0;" parent="1" source="s2_revoke" target="s2_done" edge="1">
