          </mxGeometry>
        </mxCell>
        <mxCell id="e11" value="true" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;fontColor=#82b366;fontSize=11;fontStyle=1;html=0;" parent="1" source="s2_gate" target="s2_create" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;" parent="1" source="s2_create" target="s2_check_new" edge="1">
