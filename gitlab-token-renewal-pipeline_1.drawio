      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="GitLab CI - Self-Renewal du TOKEN_GITLAB" style="text;html=0;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#1a1a2e;" parent="1" vertex="1">
          <mxGeometry x="300" y="15" width="600" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Le token (scope: api, validite 1 an) se renouvelle lui-meme avant expiration" style="text;html=0;align=center;verticalAlign=middle;fontSize=12;fontStyle=2;fontColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="300" y="48" width="600" height="25" as="geometry" />
        </mxCell>
        <mxCell id="swim_trigger" value="DECLENCHEUR" style="swimlane;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=1;fontSize=13;fontStyle=1;html=0;collapsible=0;" parent="1" vertex="1">
          <mxGeometry x="30" y="85" width="190" height="980" as="geometry" />
        </mxCell>
        <mxCell id="swim_check" value="STAGE 1 - check-token" style="swimlane;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;fontSize=13;fontStyle=1;html=0;collapsible=0;" parent="1" vertex="1">
          <mxGeometry x="240" y="85" width="370" height="980" as="geometry" />
        </mxCell>
        <mxCell id="s1_error_expired" value="ERREUR&#xa;Token expire !&#xa;Intervention manuelle" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#f8cecc;strokeColor=#b85450;shadow=1;fontSize=10;fontStyle=1;" parent="swim_check" vertex="1">
          <mxGeometry x="5" y="265" width="105" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s1_ok" value="Token OK&#xa;NEEDS_RENEWAL=false&#xa;Pipeline termine" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;fontSize=11;strokeWidth=2;" parent="swim_check" vertex="1">
          <mxGeometry x="5" y="635" width="180" height="55" as="geometry" />
