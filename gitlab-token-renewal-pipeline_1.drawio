        </mxCell>
        <mxCell id="e10" value="dotenv artifact" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#d6b656;dashed=1;dashPattern=8 4;fontSize=10;fontStyle=1;fontColor=#d6b656;html=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="s1_renew_flag" target="s2_gate" edge="1">
          <mxGeometry relative="1" as="geometry">
