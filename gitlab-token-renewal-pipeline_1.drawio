        <mxCell id="s1_end_ok" value="" style="ellipse;fillColor=#1a1a2e;strokeColor=#1a1a2e;strokeWidth=3;" parent="swim_check" vertex="1">
          <mxGeometry x="30" y="805" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="e08b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#1a1a2e;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" parent="swim_check" source="s1_ok" target="s1_end_ok" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="swim_renew" value="STAGE 2 - renew-token (self)" style="swimlane;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;fontSize=13;fontStyle=1;html=0;collapsible=0;" parent="1" vertex="1">
          <mxGeometry x="630" y="85" width="400" height="980" as="geometry" />
        </mxCell>
