apiVersion: v1
kind: Pod
metadata:
  name: route-creator
  namespace: my-namespace
spec:
  serviceAccountName: route-creator-sa
  restartPolicy: Never
  containers:
    - name: oc-cli
      image: registry.redhat.io/openshift4/ose-cli:latest
      command:
        - /bin/sh
        - -c
        - |
          oc create route reencrypt service-a-reencrypt \
            --service=service-a \
            --port=10443 \
            --cert=/etc/nginx/tls/route.crt \
            --key=/etc/nginx/tls/route.key \
            --ca-cert=/etc/nginx/tls/ca.crt \
            --dest-ca-cert=/etc/nginx/tls/ca.crt
      volumeMounts:
        - name: tls-certs
          mountPath: /etc/nginx/tls
          readOnly: true
  volumes:
    - name: tls-certs
      secret:
        secretName: nginx-tls-secret
