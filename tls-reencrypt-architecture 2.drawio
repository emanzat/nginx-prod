        <mxCell id="cronjob" value="&lt;div style=&quot;text-align:left;padding:4px;&quot;&gt;&lt;font style=&quot;font-size:10px;color:#C5A55A;font-weight:bold;&quot;&gt;🔄 CRONJOBS — Certificate Lifecycle&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&quot;font-size:12px;color:#2D3340;&quot;&gt;pod-cert-renewal&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;font-family:monospace;color:#C5A55A;background:#FFF9ED;padding:2px 6px;border-radius:8px;&quot;&gt;schedule: &amp;quot;0 2 * * *&amp;quot; (daily 2AM)&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#6B717D;&quot;&gt;&lt;b style=&quot;color:#C5A55A;&quot;&gt;1.&lt;/b&gt; &lt;font style=&quot;font-family:monospace;&quot;&gt;openssl s_client -connect my-svc.my-ns:8443&lt;/font&gt;&lt;br&gt;&lt;b style=&quot;color:#C5A55A;&quot;&gt;2.&lt;/b&gt; &lt;font style=&quot;font-family:monospace;&quot;&gt;openssl x509 -checkend 604800&lt;/font&gt; (7 jours)&lt;br&gt;&lt;b style=&quot;color:#C5A55A;&quot;&gt;3.&lt;/b&gt; Si expiring → &lt;font style=&quot;font-family:monospace;color:#D4544E;&quot;&gt;oc rollout restart deploy/my-ms&lt;/font&gt;&lt;br&gt;&lt;b style=&quot;color:#C5A55A;&quot;&gt;4.&lt;/b&gt; Sinon → &lt;font style=&quot;font-family:monospace;&quot;&gt;exit 0&lt;/font&gt; (cert still valid)&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C5A55A;strokeWidth=2;arcSize=8;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1180" y="160" width="360" height="220" as="geometry"/>
        </mxCell>

        <!-- CronJob top accent -->
        <mxCell id="cronjob_accent" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#C5A55A;strokeColor=none;arcSize=0;" vertex="1" parent="1">
          <mxGeometry x="1180" y="160" width="360" height="4" as="geometry"/>
        </mxCell>

        <!-- Arrow: CronJob → Pod (oc rollout restart) -->
        <mxCell id="arrow_cron_pod" value="&lt;font style=&quot;font-size:8px;color:#D4544E;font-family:monospace;font-weight:bold;&quot;&gt;oc rollout restart&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;exitX=0;exitY=0.7;exitDx=0;exitDy=0;entryX=1;entryY=0.15;entryDx=0;entryDy=0;strokeColor=#D4544E;strokeWidth=2;endArrow=blockThin;endFill=1;dashed=1;dashPattern=6 3;curved=1;" edge="1" source="cronjob" target="pod" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

