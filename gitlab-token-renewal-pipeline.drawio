          <mxGeometry x="1245" y="97" width="80" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg2" value="" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1210" y="122" width="20" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="leg2t" value="Décision" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1245" y="120" width="80" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg3" value="" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1215" y="145" width="20" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="leg3t" value="API GitLab" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1245" y="143" width="80" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg4" value="" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="1215" y="168" width="20" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="leg4t" value="Erreur / Alerte" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1245" y="166" width="90" height="20" as="geometry"/>
        </mxCell>

        <!-- ================================================================== -->
        <!-- SWIMLANE : SCHEDULE TRIGGER                                         -->
        <!-- ================================================================== -->
        <mxCell id="swim_trigger" value="&lt;b&gt;Déclencheur&lt;/b&gt;" style="shape=table;startSize=30;container=1;collapsible=0;childLayout=tableLayout;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=1;fontSize=13;fontStyle=1;horizontal=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="200" height="970" as="geometry"/>
        </mxCell>

        <!-- ================================================================== -->
        <!-- SWIMLANE : STAGE 1 - CHECK TOKEN                                   -->
        <!-- ================================================================== -->
        <mxCell id="swim_check" value="&lt;b&gt;Stage 1 — check-token&lt;/b&gt;" style="shape=table;startSize=30;container=1;collapsible=0;childLayout=tableLayout;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;fontSize=13;fontStyle=1;horizontal=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="280" y="80" width="380" height="970" as="geometry"/>
        </mxCell>

        <!-- ================================================================== -->
        <!-- SWIMLANE : STAGE 2 - RENEW TOKEN                                   -->
        <!-- ================================================================== -->
        <mxCell id="swim_renew" value="&lt;b&gt;Stage 2 — renew-token&lt;/b&gt;" style="shape=table;startSize=30;container=1;collapsible=0;childLayout=tableLayout;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;fontSize=13;fontStyle=1;horizontal=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="700" y="80" width="380" height="970" as="geometry"/>
        </mxCell>

        <!-- ================================================================== -->
        <!-- SWIMLANE : GITLAB SERVER                                            -->
        <!-- ================================================================== -->
        <mxCell id="swim_gitlab" value="&lt;b&gt;GitLab Server (API v4)&lt;/b&gt;" style="shape=table;startSize=30;container=1;collapsible=0;childLayout=tableLayout;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;fontSize=13;fontStyle=1;horizontal=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1120" y="80" width="60" height="970" as="geometry"/>
        </mxCell>

        <!-- ================================================================== -->
        <!-- NODES                                                               -->
        <!-- ================================================================== -->

        <!-- START : Scheduled Trigger -->
        <mxCell id="start" value="" style="ellipse;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="120" y="130" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="schedule" value="⏰ &lt;b&gt;Schedule&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Cron hebdomadaire&lt;br&gt;(ex: lundi 8h)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="200" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- STAGE 1 Nodes -->
        <mxCell id="s1_init" value="🐳 &lt;b&gt;alpine:3.19&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;apk add curl jq coreutils&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="130" width="210" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="s1_api_self" value="🔍 &lt;b&gt;GET&lt;/b&gt; /personal_access_tokens/self&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Header: PRIVATE-TOKEN: $TOKEN_GITLAB&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="220" width="250" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="s1_check_resp" value="&lt;b&gt;Réponse&lt;br&gt;valide ?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="405" y="310" width="120" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="s1_api_admin" value="🔍 &lt;b&gt;GET&lt;/b&gt; /personal_access_tokens&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;?user_id=$GITLAB_USER_ID&amp;state=active&lt;br&gt;Header: PRIVATE-TOKEN: $ADMIN_TOKEN&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="430" width="280" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="s1_extract" value="📅 &lt;b&gt;Extraire expires_at&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;jq -r '.expires_at'&lt;br&gt;Calcul DAYS_LEFT&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="540" width="210" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="s1_decision" value="&lt;b&gt;DAYS_LEFT&lt;br&gt;≤ SEUIL ?&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;(défaut: 7 jours)&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="385" y="650" width="160" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="s1_ok" value="✅ &lt;b&gt;Token OK&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;NEEDS_RENEWAL=false&lt;br&gt;Pipeline terminé&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="810" width="170" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="s1_renew_flag" value="⚠️ &lt;b&gt;Renouvellement requis&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;NEEDS_RENEWAL=true&lt;br&gt;→ dotenv artifact&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="920" width="210" height="60" as="geometry"/>
        </mxCell>

        <!-- STAGE 2 Nodes -->
        <mxCell id="s2_gate" value="&lt;b&gt;rules:&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;$NEEDS_RENEWAL&lt;br&gt;== &quot;true&quot; ?&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="820" y="130" width="140" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="s2_revoke" value="🗑️ &lt;b&gt;DELETE&lt;/b&gt; /personal_access_tokens/:id&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Révocation ancien token&lt;br&gt;Header: PRIVATE-TOKEN: $ADMIN_TOKEN&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="770" y="280" width="280" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="s2_create" value="🔑 &lt;b&gt;POST&lt;/b&gt; /users/:id/personal_access_tokens&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;name: $TOKEN_NAME&lt;br&gt;scopes: $TOKEN_SCOPES&lt;br&gt;expires_at: +90 jours&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="770" y="400" width="280" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="s2_check_new" value="&lt;b&gt;Nouveau&lt;br&gt;token reçu ?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="835" y="520" width="140" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="s2_error" value="❌ &lt;b&gt;ERREUR&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Échec création token&lt;br&gt;exit 1&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1000" y="530" width="150" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="s2_update" value="📝 &lt;b&gt;PUT&lt;/b&gt; /projects/:id/variables/TOKEN_GITLAB&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;value=$NEW_TOKEN&lt;br&gt;masked=true, protected=true&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="770" y="660" width="280" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="s2_fallback" value="&lt;b&gt;HTTP&lt;br&gt;200 ?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="845" y="770" width="120" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="s2_create_var" value="📝 &lt;b&gt;POST&lt;/b&gt; /projects/:id/variables&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;key=TOKEN_GITLAB&lt;br&gt;Création si 404&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1000" y="830" width="200" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="s2_done" value="✅ &lt;b&gt;Succès&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;TOKEN_GITLAB mis à jour&lt;br&gt;Prochaine expiration: +90j&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="805" y="920" width="210" height="60" as="geometry"/>
        </mxCell>

        <!-- END -->
        <mxCell id="end" value="" style="ellipse;fillColor=#1a1a2e;strokeColor=#1a1a2e;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="895" y="1010" width="30" height="30" as="geometry"/>
        </mxCell>

        <!-- ================================================================== -->
        <!-- EDGES (Flèches)                                                     -->
        <!-- ================================================================== -->

        <!-- Start → Schedule -->
        <mxCell id="e_start_sched" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#9673a6;" edge="1" parent="1" source="start" target="schedule">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Schedule → S1 Init -->
        <mxCell id="e_sched_s1" value="&lt;font style=&quot;font-size:10px&quot;&gt;Déclenche&lt;br&gt;le pipeline&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" parent="1" source="schedule" target="s1_init">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- S1 Init → API Self -->
        <mxCell id="e_s1_init_api" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" parent="1" source="s1_init" target="s1_api_self">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- API Self → Check Response -->
        <mxCell id="e_api_check" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;" edge="1" parent="1" source="s1_api_self" target="s1_check_resp">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Check Response → (Non) → API Admin -->
        <mxCell id="e_check_no" value="&lt;font color=&quot;#b85450&quot; style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Non&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#b85450;" edge="1" parent="1" source="s1_check_resp" target="s1_api_admin">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Check Response → (Oui) → Extract -->
        <mxCell id="e_check_yes" value="&lt;font color=&quot;#82b366&quot; style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Oui&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="s1_check_resp" target="s1_extract">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="620" y="350"/>
              <mxPoint x="620" y="570"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- API Admin → Extract -->
        <mxCell id="e_admin_extract" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;" edge="1" parent="1" source="s1_api_admin" target="s1_extract">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Extract → Decision -->
        <mxCell id="e_extract_dec" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" parent="1" source="s1_extract" target="s1_decision">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Decision → (Non) → OK -->
        <mxCell id="e_dec_ok" value="&lt;font color=&quot;#82b366&quot; style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Non&lt;br&gt;(token valide)&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="s1_decision" target="s1_ok">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="330" y="700"/>
              <mxPoint x="330" y="840"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Decision → (Oui) → Renew Flag -->
        <mxCell id="e_dec_renew" value="&lt;font color=&quot;#b85450&quot; style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Oui&lt;br&gt;(expire bientôt)&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#b85450;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1" source="s1_decision" target="s1_renew_flag">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="465" y="790"/>
              <mxPoint x="465" y="900"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Renew Flag → S2 Gate (dotenv artifact) -->
        <mxCell id="e_flag_gate" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;dotenv&lt;br&gt;artifact&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#d6b656;dashed=1;dashPattern=8 4;exitX=1;exitY=0;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="s1_renew_flag" target="s2_gate">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="680" y="920"/>
              <mxPoint x="680" y="175"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- S2 Gate → Revoke -->
        <mxCell id="e_gate_revoke" value="&lt;font color=&quot;#82b366&quot; style=&quot;font-size:10px&quot;&gt;&lt;b&gt;true&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;" edge="1" parent="1" source="s2_gate" target="s2_revoke">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Revoke → Create -->
        <mxCell id="e_revoke_create" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;" edge="1" parent="1" source="s2_revoke" target="s2_create">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Create → Check New -->
        <mxCell id="e_create_check" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;" edge="1" parent="1" source="s2_create" target="s2_check_new">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Check New → (Non) → Error -->
        <mxCell id="e_check_error" value="&lt;font color=&quot;#b85450&quot; style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Non&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#b85450;" edge="1" parent="1" source="s2_check_new" target="s2_error">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Check New → (Oui) → Update -->
        <mxCell id="e_check_update" value="&lt;font color=&quot;#82b366&quot; style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Oui&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;" edge="1" parent="1" source="s2_check_new" target="s2_update">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Update → Fallback check -->
        <mxCell id="e_update_fallback" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;" edge="1" parent="1" source="s2_update" target="s2_fallback">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Fallback → (404) → Create Var -->
        <mxCell id="e_fallback_create" value="&lt;font color=&quot;#d6b656&quot; style=&quot;font-size:10px&quot;&gt;&lt;b&gt;404&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#d6b656;" edge="1" parent="1" source="s2_fallback" target="s2_create_var">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Fallback → (200) → Done -->
        <mxCell id="e_fallback_done" value="&lt;font color=&quot;#82b366&quot; style=&quot;font-size:10px&quot;&gt;&lt;b&gt;200&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1" source="s2_fallback" target="s2_done">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Create Var → Done -->
        <mxCell id="e_createvar_done" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;" edge="1" parent="1" source="s2_create_var" target="s2_done">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Done → End -->
        <mxCell id="e_done_end" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#1a1a2e;" edge="1" parent="1" source="s2_done" target="end">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ================================================================== -->
        <!-- ANNOTATIONS : Variables CI/CD                                       -->
        <!-- ================================================================== -->
        <mxCell id="vars_box" value="&lt;b&gt;Variables CI/CD requises&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;• &lt;b&gt;ADMIN_TOKEN&lt;/b&gt; — PAT admin (scope: api)&lt;br&gt;• &lt;b&gt;TOKEN_GITLAB&lt;/b&gt; — Token à surveiller&lt;br&gt;• &lt;b&gt;GITLAB_USER_ID&lt;/b&gt; — ID du user&lt;br&gt;• &lt;b&gt;TOKEN_NAME&lt;/b&gt; — Nom du token&lt;br&gt;• &lt;b&gt;TOKEN_SCOPES&lt;/b&gt; — Scopes&lt;br&gt;• &lt;b&gt;RENEW_THRESHOLD_DAYS&lt;/b&gt; — Seuil (7)&lt;br&gt;• &lt;b&gt;TOKEN_VALIDITY_DAYS&lt;/b&gt; — Durée (90)&lt;/font&gt;" style="shape=note;size=15;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="320" width="210" height="170" as="geometry"/>
        </mxCell>

        <!-- Annotation: API endpoints -->
        <mxCell id="api_note" value="&lt;b&gt;API GitLab v4 Endpoints&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:9px&quot;&gt;GET /personal_access_tokens/self&lt;br&gt;GET /personal_access_tokens?user_id=&lt;br&gt;DELETE /personal_access_tokens/:id&lt;br&gt;POST /users/:id/personal_access_tokens&lt;br&gt;PUT /projects/:id/variables/:key&lt;br&gt;POST /projects/:id/variables&lt;/font&gt;" style="shape=note;size=15;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=10;shadow=1;" vertex="1" parent="1">
